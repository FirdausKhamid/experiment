{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": { "dependsOn": ["^build"], "outputs": [] },
    "test:cov": { "dependsOn": ["^build"], "outputs": ["coverage/**"] }
  }
}
